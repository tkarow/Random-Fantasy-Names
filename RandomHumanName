function Get-HumanName {

    Param(
        [parameter(Mandatory=$False)]
        [ValidateSet("Male","Female")]
        [string]$Gender,
        [parameter(Mandatory=$False)]
        [ValidateSet("England","Greenland","Ireland","Norway")]
        [string]$Nation,
        [parameter(Mandatory=$False)]
        [bool]$ShowWork
    )

    #region Set Parameters if needed

    $GenderRoll = ""
    $GenderRoll = Get-Random -Minimum 1 -Maximum 5

    if(($Gender -like $null) -or ($Gender -eq "")){if($GenderRoll -ge 3){$Gender = "Male"}else{$Gender = "Female"}}

    $NationCount = ""
    $NationCount = ($HumanNames.Nation | sort | Get-Unique | Measure).Count
    
    $UniqueNations = ""
    $UniqueNations = $HumanNames.Nation | sort | Get-Unique

    $NationRoll = ""
    $NationRoll = Get-Random -Minimum 0 -Maximum ($NationCount - 1)

    if(($Nation -like $null) -or ($Nation -eq "")){$Nation = $UniqueNations[$NationRoll]}

    #endregion

    $FilteredNames = ""
    $FilteredNames = $HumanNames | ?{($_.Gender -eq $Gender) -and ($_.Nation -eq $Nation)}

    $PossibleNames = @()

    foreach($Row in $FilteredNames){
    
        $PossibleNames += [pscustomobject]@{Name=$Row.Name;Nation=$Row.Nation;Percentage=($Row.Percentage * 1000);Gender=$Row.Gender}

    }

    $Max = ""
    $Max = [int]($PossibleNames.Percentage | Measure -Sum).Sum

    $Result = ""
    $Result = Get-Random -Minimum 1 -Maximum ($Max - 1)

    $Table = ""
    $Table = @()

    $i = 0

    foreach($Entry in $PossibleNames){
    
        $i = $i + 1

        $Table += [pscustomobject]@{Min = $i;Max = ($i + $Entry.Percentage);Object = $Entry}

        $i = $i + $Entry.Percentage

    }

    if($ShowWork -eq $true){[pscustomobject]@{RandomName=($Table | ?{($Result -le $_.Max) -and ($Result -ge $_.Min)}).Object.Name;Table=$Table;Roll=$Result}}else{($Table | ?{($Result -le $_.Max) -and ($Result -ge $_.Min)}).Object.Name}

}

