function Get-HumanName {

    Param(
        [parameter(Mandatory=$False)]
        [ValidateSet("Male","Female")]
        [string]$Gender,
        [parameter(Mandatory=$False)]
        [ValidateSet("England 1377","Greenland 1961","Ireland 1964","Norway 1945", "Domesday 1086")]
        [string]$Source,
        [parameter(Mandatory=$False)]
        [bool]$ShowWork,
        [parameter(Mandatory=$False)]
        [bool]$Rare
    )

    #region Set Parameters if needed

    $GenderRoll = ""
    $GenderRoll = Get-Random -Minimum 1 -Maximum 5

    if(($Gender -like $null) -or ($Gender -eq "")){if($GenderRoll -ge 3){$Gender = "Male"}else{$Gender = "Female"}}

    $SourceCount = ""
    $SourceCount = ($HumanNames.Source | sort | Get-Unique | Measure).Count
    
    $UniqueSources = ""
    $UniqueSources = $HumanNames.Source | sort | Get-Unique

    $SourceRoll = ""
    $SourceRoll = Get-Random -Minimum 0 -Maximum ($SourceCount - 1)

    if(($Source -like $null) -or ($Source -eq "")){$Source = $UniqueSources[$SourceRoll]}

    #endregion

    $FilteredNames = ""
    $FilteredNames = $HumanNames | ?{($_.Gender -eq $Gender) -and ($_.Source -eq $Source)}

    $PossibleNames = @()

    foreach($Row in $FilteredNames){
    
        $PossibleNames += [pscustomobject]@{Name=$Row.Name;Source=$Row.Source;Weight=$(if($Row.Weight * 1000 > 1){[math]::Round($Row.Weight * 1000)}else{1});Gender=$Row.Gender}

    }

    $Table = ""
    $Table = @()

    $i = 0

    foreach($Entry in $PossibleNames){
    
        $i = $i + 1

        $Table += [pscustomobject]@{Min = $i;Max = ($i + $Entry.Weight);Object = $Entry}

        $i = $i + $Entry.Weight

    }

    $Max = ""
    $Max = $Table[-1].Max

    $Result = ""
    $Result = [int](Get-Random -Minimum 1 -Maximum ($Max - 1))

    $Table = $Table | Sort-Object -Property {$_.Object.Weight } -Descending

    if($Rare -eq $true){
    
        $RareMin = [math]::Round($Max * .85)

        $Result = [int](Get-Random -Minimum $RareMin -Maximum ($Max - 1))

    }

    if($ShowWork -eq $true){[pscustomobject]@{RandomName=($Table | ?{($Result -le $_.Max) -and ($Result -ge $_.Min)}).Object.Name;Table=$Table;Roll=$Result}}else{($Table | ?{($Result -le $_.Max) -and ($Result -ge $_.Min)}).Object.Name}

}

